# Database
DATABASE_URL="postgresql://cestari_user:cestari_secure_2025@localhost:5442/gruppo_cestari"

# Redis
REDIS_URL="redis://:cestari_redis_2025@localhost:6387"

# NextAuth
NEXTAUTH_URL="https://cestari.fodivps1.cloud"
NEXTAUTH_SECRET="generate-32-char-secret-here"

# MinIO (Centrale)
MINIO_ENDPOINT="http://127.0.0.1:9000"
MINIO_ACCESS_KEY="vps_minio_admin"
MINIO_SECRET_KEY="your-minio-secret-key"
MINIO_BUCKET="gruppo-cestari"
MINIO_PUBLIC_URL="https://s3.fodivps1.cloud"

# SMTP
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="noreply@fodisrl.it"
SMTP_PASS="your-smtp-password"

# Resend (optional, preferred for transactional)
RESEND_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="https://cestari.fodivps1.cloud"
NEXT_PUBLIC_APP_NAME="Gruppo Cestari"

# Cloudflare Turnstile (Anti-bot protection)
# Get keys from: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
